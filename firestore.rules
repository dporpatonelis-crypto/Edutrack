rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'teacher' | 'student')
    //   - createdAt: timestamp (optional)
    //
    // Collection: scenarios
    // Document ID: {scenarioId}
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - teacherId: string (required)
    //   - steps: list (required)
    //   - createdAt: timestamp (optional)
    //
    // Collection: progress
    // Document ID: {progressId}
    // Fields:
    //   - userId: string (required)
    //   - scenarioId: string (required)
    //   - completedSteps: list (required)
    //   - lastUpdated: timestamp (optional)
    //
    // Collection: profile_content
    // Document ID: {contentId}
    // Fields:
    //   - userId: string (required)
    //   - type: string (required, 'about' | 'academic')
    //   - content: string (optional)
    //   - images: list (optional)
    //   - backgroundImage: string (optional)
    //   - backgroundOpacity: number (optional)
    //   - lastUpdated: timestamp (optional)
    //
    // Collection: tab_settings
    // Document ID: {settingId}
    // Fields:
    //   - userId: string (required)
    //   - tabId: string (required)
    //   - backgroundImage: string (optional)
    //   - backgroundOpacity: number (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "dporpatonelis@gmail.com";
    }

    function isTeacher() {
      return isAuthenticated() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher')
      );
    }

    function isDocOwner() {
      return isAuthenticated() && 
        (resource == null || resource.data.teacherId == request.auth.uid);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['teacher', 'student'];
    }

    function isValidScenario(data) {
      return data.keys().hasAll(['title', 'teacherId', 'steps']) &&
             data.title is string && data.title.size() < 200 &&
             data.teacherId is string &&
             data.steps is list && data.steps.size() < 50;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['userId', 'scenarioId', 'completedSteps']) &&
             data.userId is string &&
             data.scenarioId is string &&
             data.completedSteps is list;
    }

    function isValidProfileContent(data) {
      return data.keys().hasAll(['userId', 'type']) &&
             data.userId is string &&
             data.type in ['about', 'academic'];
    }

    function isValidTabSetting(data) {
      return data.keys().hasAll(['userId', 'tabId']) &&
             data.userId is string &&
             data.tabId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /scenarios/{scenarioId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() && isValidScenario(request.resource.data) && request.resource.data.teacherId == request.auth.uid;
      allow update: if isTeacher() && (resource.data.teacherId == request.auth.uid || isAdmin()) && isValidScenario(request.resource.data);
      allow delete: if isTeacher() && (resource.data.teacherId == request.auth.uid || isAdmin());
    }

    match /progress/{progressId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isTeacher());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidProgress(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidProgress(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /profile_content/{contentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidProfileContent(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidProfileContent(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /tab_settings/{settingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidTabSetting(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidTabSetting(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
